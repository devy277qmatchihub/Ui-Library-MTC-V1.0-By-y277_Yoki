	local Window = {}
	Window._tabs = {}
	Window._selectedTab = nil
	Window._discordLink = nil
	Window._theme = Theme
	Window._iconMap = IconMap
	Window._binds = {
		bg = {},
		top = {},
		side = {},
		card = {},
		button = {},
		input = {},
		text = {},
		sub = {},
		stroke = {},
		fill = {},
	}

	local function bind(group, obj, prop)
		table.insert(Window._binds[group], { obj = obj, prop = prop })
	end

	local function resolveIcon(icon)
		if not icon or icon == "" then
			return ""
		end
		if string.sub(icon, 1, 12) == "rbxassetid://" then
			return icon
		end
		if string.sub(icon, 1, 9) == "lucide://" then
			local key = string.sub(icon, 10)
			return Window._iconMap[key] or ""
		end
		return Window._iconMap[icon] or icon
	end

	function Window:RegisterIcon(name, imageId)
		if not name or not imageId then return end
		Window._iconMap[name] = imageId
	end

	local function applyTheme(t)
		Window._theme = t

		for _, r in ipairs(Window._binds.bg) do
			if r.obj and r.obj.Parent then r.obj[r.prop] = t.BG end
		end
		for _, r in ipairs(Window._binds.top) do
			if r.obj and r.obj.Parent then r.obj[r.prop] = t.Top end
		end
		for _, r in ipairs(Window._binds.side) do
			if r.obj and r.obj.Parent then r.obj[r.prop] = t.Sidebar end
		end
		for _, r in ipairs(Window._binds.card) do
			if r.obj and r.obj.Parent then r.obj[r.prop] = t.Card end
		end
		for _, r in ipairs(Window._binds.button) do
			if r.obj and r.obj.Parent then r.obj[r.prop] = t.Button end
		end
		for _, r in ipairs(Window._binds.input) do
			if r.obj and r.obj.Parent then r.obj[r.prop] = t.Input end
		end
		for _, r in ipairs(Window._binds.text) do
			if r.obj and r.obj.Parent then r.obj[r.prop] = t.Text end
		end
		for _, r in ipairs(Window._binds.sub) do
			if r.obj and r.obj.Parent then r.obj[r.prop] = t.SubText end
		end
		for _, r in ipairs(Window._binds.stroke) do
			if r.obj and r.obj.Parent then r.obj[r.prop] = t.Stroke end
		end
		for _, r in ipairs(Window._binds.fill) do
			if r.obj and r.obj.Parent then r.obj[r.prop] = t.Fill end
		end

		Main.BackgroundColor3 = t.BG
		MainStroke.Color = t.Stroke

		TopBar.BackgroundColor3 = t.Top
		TopStroke.Color = t.Stroke
		TopMask.BackgroundColor3 = t.Top

		Sidebar.BackgroundColor3 = t.Sidebar
		SideStroke.Color = t.Stroke

		Title.TextColor3 = t.Text
		LeftIconText.TextColor3 = t.Text
		CloseText.TextColor3 = t.Text

		DiscordBanner.BackgroundColor3 = t.Card
		DiscordStrokeObj.Color = t.Stroke
		DiscordBannerTitle.TextColor3 = t.Text
		DiscordBannerSub.TextColor3 = t.SubText
		DiscordButton.BackgroundColor3 = t.Button
		DiscordButtonStroke.Color = t.Stroke
		DiscordButton.TextColor3 = t.Text

		for _, tab in pairs(Window._tabs) do
			tab.Button.BackgroundColor3 = tab.Active and t.Accent or t.Button
			tab.Button.TextColor3 = t.Text
			tab.ButtonStroke.Color = t.Stroke
			if tab.Icon then
				tab.Icon.ImageColor3 = t.Text
			end
		end
	end

	local function openExternal(link)
		if not link or link == "" then return end
		pcall(function()
			if setclipboard then
				setclipboard(link)
			end
		end)
		pcall(function()
			GuiService:OpenBrowserWindow(link)
		end)
	end

	CloseText.MouseButton1Click:Connect(function()
		Gui:Destroy()
	end)

	CloseIcon.MouseButton1Click:Connect(function()
		Gui:Destroy()
	end)

	DiscordButton.MouseButton1Click:Connect(function()
		if Window._discordLink then
			openExternal(Window._discordLink)
		end
	end)

	-- Drag window
	do
		local dragging = false
		local dragStart
		local startPos
		local dragInput

		TopBar.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				dragging = true
				dragStart = input.Position
				startPos = Main.Position
				input.Changed:Connect(function()
					if input.UserInputState == Enum.UserInputState.End then
						dragging = false
					end
				end)
			end
		end)

		TopBar.InputChanged:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
				dragInput = input
			end
		end)

		UIS.InputChanged:Connect(function(input)
			if dragging and input == dragInput then
				local delta = input.Position - dragStart
				Main.Position = UDim2.new(
					startPos.X.Scale,
					startPos.X.Offset + delta.X,
					startPos.Y.Scale,
					startPos.Y.Offset + delta.Y
				)
			end
		end)
	end

	local function makeSection(tabPage, titleText, sectionIcon)
		local Section = new("Frame", {
			Parent = tabPage,
			BackgroundColor3 = Theme.Card,
			BorderSizePixel = 0,
			Size = UDim2.new(1, 0, 0, 0),
			AutomaticSize = Enum.AutomaticSize.Y
		})
		corner(Section, 10)
		local SectionStroke = stroke(Section, Theme.Stroke, 1)

		local Icon
		local iconResolved = resolveIcon(sectionIcon)
		if iconResolved ~= "" then
			Icon = new("ImageLabel", {
				Parent = Section,
				BackgroundTransparency = 1,
				Position = UDim2.new(0, 10, 0, 10),
				Size = UDim2.new(0, 16, 0, 16),
				Image = iconResolved,
				ScaleType = Enum.ScaleType.Fit,
				ImageColor3 = Theme.Text
			})
		end

		local SectionTitle = new("TextLabel", {
			Parent = Section,
			BackgroundTransparency = 1,
			Size = UDim2.new(1, -20, 0, 28),
			Position = UDim2.new(0, Icon and 32 or 10, 0, 6),
			Text = titleText or "Section",
			TextColor3 = Theme.Text,
			Font = Enum.Font.GothamBold,
			TextSize = 13,
			TextXAlignment = Enum.TextXAlignment.Left
		})

		local Body = new("Frame", {
			Parent = Section,
			BackgroundTransparency = 1,
			Position = UDim2.new(0, 10, 0, 34),
			Size = UDim2.new(1, -20, 0, 0),
			AutomaticSize = Enum.AutomaticSize.Y
		})

		local Layout = new("UIListLayout", {
			Parent = Body,
			Padding = UDim.new(0, 8),
			SortOrder = Enum.SortOrder.LayoutOrder
		})

		new("UIPadding", {
			Parent = Body,
			PaddingBottom = UDim.new(0, 10)
		})

		bind("card", Section, "BackgroundColor3")
		bind("stroke", SectionStroke, "Color")
		bind("text", SectionTitle, "TextColor3")
		if Icon then
			bind("text", Icon, "ImageColor3")
		end

		local SectionApi = {}

		function SectionApi:AddLabel(text)
			local Label = new("TextLabel", {
				Parent = Body,
				BackgroundTransparency = 1,
				Size = UDim2.new(1, 0, 0, 24),
				Text = text or "Label",
				TextColor3 = Theme.Text,
				Font = Enum.Font.Gotham,
				TextSize = 13,
				TextXAlignment = Enum.TextXAlignment.Left
			})
			bind("text", Label, "TextColor3")
			return Label
		end

		function SectionApi:AddButton(text, callback, icon)
			local Row = new("Frame", {
				Parent = Body,
				BackgroundColor3 = Theme.Button,
				BorderSizePixel = 0,
				Size = UDim2.new(1, 0, 0, 40)
			})
			corner(Row, 8)
			local RowStroke = stroke(Row, Theme.Stroke, 1)

			local iconResolved = resolveIcon(icon)
			local IconLabel
			local textX = 12
			if iconResolved ~= "" then
				IconLabel = new("ImageLabel", {
					Parent = Row,
					BackgroundTransparency = 1,
					Position = UDim2.new(0, 12, 0.5, -9),
					Size = UDim2.new(0, 18, 0, 18),
					Image = iconResolved,
					ScaleType = Enum.ScaleType.Fit,
					ImageColor3 = Theme.Text
				})
				textX = 38
				bind("text", IconLabel, "ImageColor3")
			end

			local Btn = new("TextButton", {
				Parent = Row,
				BackgroundTransparency = 1,
				Size = UDim2.new(1, 0, 1, 0),
				Text = text or "Button",
				TextColor3 = Theme.Text,
				Font = Enum.Font.GothamSemibold,
				TextSize = 13,
				AutoButtonColor = false,
				TextXAlignment = Enum.TextXAlignment.Left
			})
			Btn.TextXAlignment = Enum.TextXAlignment.Left
			Btn.Position = UDim2.new(0, textX, 0, 0)

			bind("button", Row, "BackgroundColor3")
			bind("stroke", RowStroke, "Color")
			bind("text", Btn, "TextColor3")

			Btn.MouseButton1Click:Connect(function()
				if callback then
					task.spawn(callback)
				end
			end)

			return Btn
		end

		function SectionApi:AddToggle(text, defaultValue, callback, icon)
			local state = defaultValue and true or false

			local Row = new("TextButton", {
				Parent = Body,
				BackgroundColor3 = Theme.Button,
				BorderSizePixel = 0,
				Size = UDim2.new(1, 0, 0, 46),
				Text = "",
				AutoButtonColor = false
			})
			corner(Row, 9)
			local RowStroke = stroke(Row, Theme.Stroke, 1)

			local iconResolved = resolveIcon(icon)
			local IconLabel
			local textX = 12
			if iconResolved ~= "" then
				IconLabel = new("ImageLabel", {
					Parent = Row,
					BackgroundTransparency = 1,
					Position = UDim2.new(0, 12, 0.5, -9),
					Size = UDim2.new(0, 18, 0, 18),
					Image = iconResolved,
					ScaleType = Enum.ScaleType.Fit,
					ImageColor3 = Theme.Text
				})
				textX = 38
				bind("text", IconLabel, "ImageColor3")
			end

			local Label = new("TextLabel", {
				Parent = Row,
				BackgroundTransparency = 1,
				Position = UDim2.new(0, textX, 0, 0),
				Size = UDim2.new(1, -100, 1, 0),
				Text = text or "Toggle",
				TextColor3 = Theme.Text,
				Font = Enum.Font.GothamSemibold,
				TextSize = 13,
				TextXAlignment = Enum.TextXAlignment.Left
			})

			local Switch = new("Frame", {
				Parent = Row,
				BackgroundColor3 = state and Theme.Accent or Theme.Stroke,
				BorderSizePixel = 0,
				Size = UDim2.new(0, 48, 0, 24),
				Position = UDim2.new(1, -60, 0.5, -12)
			})
			corner(Switch, 999)

			local Knob = new("Frame", {
				Parent = Switch,
				BackgroundColor3 = Color3.fromRGB(255, 255, 255),
				BorderSizePixel = 0,
				Size = UDim2.new(0, 18, 0, 18),
				Position = state and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 3, 0.5, -9)
			})
			corner(Knob, 999)

			bind("button", Row, "BackgroundColor3")
			bind("stroke", RowStroke, "Color")
			bind("text", Label, "TextColor3")
			bind("fill", Switch, "BackgroundColor3")

			local function render()
				local goalPos = state and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 3, 0.5, -9)
				TweenService:Create(Knob, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
					Position = goalPos
				}):Play()
				TweenService:Create(Switch, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
					BackgroundColor3 = state and Theme.Accent or Theme.Stroke
				}):Play()

				if callback then
					task.spawn(callback, state)
				end
			end

			Row.MouseButton1Click:Connect(function()
				state = not state
				render()
			end)

			local Toggle = {}

			function Toggle:Set(v)
				state = v and true or false
				render()
			end

			function Toggle:Get()
				return state
			end

			render()
			return Toggle
		end

		function SectionApi:AddSlider(text, minValue, maxValue, defaultValue, callback)
			minValue = minValue or 0
			maxValue = maxValue or 100
			defaultValue = defaultValue or minValue

			local value = math.clamp(defaultValue, minValue, maxValue)
			local dragging = false

			local Row = new("Frame", {
				Parent = Body,
				BackgroundColor3 = Theme.Button,
				BorderSizePixel = 0,
				Size = UDim2.new(1, 0, 0, 66)
			})
			corner(Row, 9)
			local RowStroke = stroke(Row, Theme.Stroke, 1)

			local Label = new("TextLabel", {
				Parent = Row,
				BackgroundTransparency = 1,
				Position = UDim2.new(0, 10, 0, 7),
				Size = UDim2.new(1, -20, 0, 16),
				Text = text or "Slider",
				TextColor3 = Theme.Text,
				Font = Enum.Font.GothamSemibold,
				TextSize = 13,
				TextXAlignment = Enum.TextXAlignment.Left
			})

			local ValueLabel = new("TextLabel", {
				Parent = Row,
				BackgroundTransparency = 1,
				Position = UDim2.new(0, 10, 0, 7),
				Size = UDim2.new(1, -20, 0, 16),
				Text = tostring(value),
				TextColor3 = Theme.SubText,
				Font = Enum.Font.Gotham,
				TextSize = 12,
				TextXAlignment = Enum.TextXAlignment.Right
			})

			local Bar = new("Frame", {
				Parent = Row,
				BackgroundColor3 = Theme.Input,
				BorderSizePixel = 0,
				Position = UDim2.new(0, 10, 0, 36),
				Size = UDim2.new(1, -20, 0, 10)
			})
			corner(Bar, 999)

			local Fill = new("Frame", {
				Parent = Bar,
				BackgroundColor3 = Theme.Accent,
				BorderSizePixel = 0,
				Size = UDim2.new(0, 0, 1, 0)
			})
			corner(Fill, 999)

			local Knob = new("Frame", {
				Parent = Bar,
				BackgroundColor3 = Color3.fromRGB(255, 255, 255),
				BorderSizePixel = 0,
				AnchorPoint = Vector2.new(0.5, 0.5),
				Position = UDim2.new(0, 0, 0.5, 0),
				Size = UDim2.new(0, 14, 0, 14)
			})
			corner(Knob, 999)

			bind("button", Row, "BackgroundColor3")
			bind("stroke", RowStroke, "Color")
			bind("input", Bar, "BackgroundColor3")
			bind("fill", Fill, "BackgroundColor3")
			bind("text", Label, "TextColor3")
			bind("sub", ValueLabel, "TextColor3")

			local function applyValue(v, tween)
				v = math.clamp(v, minValue, maxValue)
				value = v
				ValueLabel.Text = tostring(value)

				local alpha = 0
				if maxValue ~= minValue then
					alpha = (value - minValue) / (maxValue - minValue)
				end

				local fillGoal = { Size = UDim2.new(alpha, 0, 1, 0) }
				local knobGoal = { Position = UDim2.new(alpha, 0, 0.5, 0) }

				if tween then
					TweenService:Create(Fill, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), fillGoal):Play()
					TweenService:Create(Knob, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), knobGoal):Play()
				else
					Fill.Size = fillGoal.Size
					Knob.Position = knobGoal.Position
				end

				if callback then
					task.spawn(callback, value)
				end
			end

			local function updateFromInput(inputPos)
				local x = math.clamp((inputPos.X - Bar.AbsolutePosition.X) / Bar.AbsoluteSize.X, 0, 1)
				local newValue = math.floor((minValue + (maxValue - minValue) * x) + 0.5)
				applyValue(newValue, true)
			end

			Bar.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					dragging = true
					updateFromInput(input.Position)
				end
			end)

			Bar.InputChanged:Connect(function(input)
				if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
					updateFromInput(input.Position)
				end
			end)

			UIS.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					dragging = false
				end
			end)

			local Slider = {}

			function Slider:Set(v)
				applyValue(v, true)
			end

			function Slider:Get()
				return value
			end

			applyValue(value, false)
			return Slider
		end

		function SectionApi:AddDropdown(text, options, callback, icon)
			options = options or {}
			local opened = false
			local selected = nil

			local Holder = new("Frame", {
				Parent = Body,
				BackgroundColor3 = Theme.Button,
				BorderSizePixel = 0,
				Size = UDim2.new(1, 0, 0, 40)
			})
			corner(Holder, 9)
			local HolderStroke = stroke(Holder, Theme.Stroke, 1)

			local iconResolved = resolveIcon(icon)
			local IconLabel
			local textX = 12
			if iconResolved ~= "" then
				IconLabel = new("ImageLabel", {
					Parent = Holder,
					BackgroundTransparency = 1,
					Position = UDim2.new(0, 12, 0.5, -9),
					Size = UDim2.new(0, 18, 0, 18),
					Image = iconResolved,
					ScaleType = Enum.ScaleType.Fit,
					ImageColor3 = Theme.Text
				})
				textX = 38
				bind("text", IconLabel, "ImageColor3")
			end

			local MainButton = new("TextButton", {
				Parent = Holder,
				BackgroundTransparency = 1,
				Size = UDim2.new(1, 0, 0, 40),
				Text = "",
				AutoButtonColor = false
			})

			local Label = new("TextLabel", {
				Parent = Holder,
				BackgroundTransparency = 1,
				Position = UDim2.new(0, textX, 0, 0),
				Size = UDim2.new(1, -50, 1, 0),
				Text = text or "Dropdown",
				TextColor3 = Theme.Text,
				Font = Enum.Font.GothamSemibold,
				TextSize = 13,
				TextXAlignment = Enum.TextXAlignment.Left
			})

			local Arrow = new("TextLabel", {
				Parent = Holder,
				BackgroundTransparency = 1,
				Position = UDim2.new(1, -26, 0, 0),
				Size = UDim2.new(0, 14, 1, 0),
				Text = "▼",
				TextColor3 = Theme.SubText,
				Font = Enum.Font.GothamBold,
				TextSize = 12
			})

			local List = new("Frame", {
				Parent = Holder,
				BackgroundColor3 = Theme.Card,
				BorderSizePixel = 0,
				Position = UDim2.new(0, 0, 0, 44),
				Size = UDim2.new(1, 0, 0, 0),
				ClipsDescendants = true,
				Visible = false
			})
			corner(List, 8)
			local ListStroke = stroke(List, Theme.Stroke, 1)

			local ListLayout = new("UIListLayout", {
				Parent = List,
				Padding = UDim.new(0, 6),
				SortOrder = Enum.SortOrder.LayoutOrder
			})

			new("UIPadding", {
				Parent = List,
				PaddingTop = UDim.new(0, 6),
				PaddingBottom = UDim.new(0, 6),
				PaddingLeft = UDim.new(0, 6),
				PaddingRight = UDim.new(0, 6)
			})

			bind("button", Holder, "BackgroundColor3")
			bind("stroke", HolderStroke, "Color")
			bind("text", Label, "TextColor3")
			bind("sub", Arrow, "TextColor3")
			bind("card", List, "BackgroundColor3")
			bind("stroke", ListStroke, "Color")

			local function refreshList()
				for _, child in ipairs(List:GetChildren()) do
					if child:IsA("TextButton") then
						child:Destroy()
					end
				end

				for _, opt in ipairs(options) do
					local Item = new("TextButton", {
						Parent = List,
						BackgroundColor3 = Theme.Input,
						BorderSizePixel = 0,
						Size = UDim2.new(1, 0, 0, 32),
						Text = tostring(opt),
						TextColor3 = Theme.Text,
						Font = Enum.Font.Gotham,
						TextSize = 13,
						AutoButtonColor = false
					})
					corner(Item, 7)
					local ItemStroke = stroke(Item, Theme.Stroke, 1)

					bind("input", Item, "BackgroundColor3")
					bind("text", Item, "TextColor3")
					bind("stroke", ItemStroke, "Color")

					Item.MouseButton1Click:Connect(function()
						selected = tostring(opt)
						Label.Text = (text or "Dropdown") .. " : " .. selected
						opened = false
						List.Visible = false
						Holder.Size = UDim2.new(1, 0, 0, 40)
						Arrow.Text = "▼"
						if callback then
							task.spawn(callback, selected)
						end
					end)
				end

				List.Size = UDim2.new(1, 0, 0, math.min(200, 12 + (#options * 38)))
			end

			MainButton.MouseButton1Click:Connect(function()
				opened = not opened
				List.Visible = opened
				Arrow.Text = opened and "▲" or "▼"
				Holder.Size = opened and UDim2.new(1, 0, 0, 44 + List.Size.Y.Offset) or UDim2.new(1, 0, 0, 40)
			end)

			refreshList()

			local Dropdown = {}

			function Dropdown:SetOptions(newOptions)
				options = newOptions or {}
				refreshList()
			end

			function Dropdown:Set(v)
				selected = tostring(v)
				Label.Text = (text or "Dropdown") .. " : " .. selected
				if callback then
					task.spawn(callback, selected)
				end
			end

			function Dropdown:Get()
				return selected
			end

			return Dropdown
		end

		return SectionApi
	end

	local function makeTab(name, iconId)
		local resolvedIcon = resolveIcon(iconId)

		local TabButton = new("TextButton", {
			Parent = TabList,
			BackgroundColor3 = Theme.Button,
			BorderSizePixel = 0,
			Size = UDim2.new(1, 0, 0, 38),
			Text = "",
			AutoButtonColor = false
		})
		corner(TabButton, 8)
		local TabStroke = stroke(TabButton, Theme.Stroke, 1)

		local IconLabel
		local textX = 12
		if resolvedIcon ~= "" then
			IconLabel = new("ImageLabel", {
				Parent = TabButton,
				BackgroundTransparency = 1,
				Position = UDim2.new(0, 10, 0.5, -8),
				Size = UDim2.new(0, 16, 0, 16),
				Image = resolvedIcon,
				ScaleType = Enum.ScaleType.Fit,
				ImageColor3 = Theme.Text
			})
			textX = 34
			bind("text", IconLabel, "ImageColor3")
		end

		local TabText = new("TextLabel", {
			Parent = TabButton,
			BackgroundTransparency = 1,
			Position = UDim2.new(0, textX, 0, 0),
			Size = UDim2.new(1, -textX - 10, 1, 0),
			Text = name,
			TextColor3 = Theme.Text,
			Font = Enum.Font.GothamSemibold,
			TextSize = 13,
			TextXAlignment = Enum.TextXAlignment.Left
		})

		local TabPage = new("ScrollingFrame", {
			Parent = PagesFolder,
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			Size = UDim2.new(1, 0, 1, 0),
			Visible = false,
			ScrollBarThickness = 4,
			CanvasSize = UDim2.new(0, 0, 0, 0),
			AutomaticCanvasSize = Enum.AutomaticSize.Y
		})

		local PageLayout = new("UIListLayout", {
			Parent = TabPage,
			Padding = UDim.new(0, 10),
			SortOrder = Enum.SortOrder.LayoutOrder
		})

		new("UIPadding", {
			Parent = TabPage,
			PaddingTop = UDim.new(0, 10),
			PaddingLeft = UDim.new(0, 10),
			PaddingRight = UDim.new(0, 10),
			PaddingBottom = UDim.new(0, 10)
		})

		bind("button", TabButton, "BackgroundColor3")
		bind("text", TabText, "TextColor3")
		bind("stroke", TabStroke, "Color")

		local TabData = {
			Active = false,
			Button = TabButton,
			Page = TabPage,
			ButtonStroke = TabStroke,
			Icon = IconLabel,
			MainSection = nil
		}

		local function setActive(state)
			TabData.Active = state
			TabPage.Visible = state
			TabButton.BackgroundColor3 = state and Theme.Accent or Theme.Button
		end

		TabButton.MouseButton1Click:Connect(function()
			for _, t in pairs(Window._tabs) do
				t.SetActive(false)
			end
			setActive(true)
			Window._selectedTab = TabData
		end)

		function TabData.SetActive(state)
			setActive(state)
		end

		TabData.MainSection = makeSection(TabPage, "Main")

		function TabData:AddSection(sectionTitle, sectionIcon)
			return makeSection(TabPage, sectionTitle, sectionIcon)
		end

		function TabData:AddLabel(text)
			return TabData.MainSection:AddLabel(text)
		end

		function TabData:AddButton(text, callback, icon)
			return TabData.MainSection:AddButton(text, callback, icon)
		end

		function TabData:AddToggle(text, defaultValue, callback, icon)
			return TabData.MainSection:AddToggle(text, defaultValue, callback, icon)
		end

		function TabData:AddSlider(text, minValue, maxValue, defaultValue, callback)
			return TabData.MainSection:AddSlider(text, minValue, maxValue, defaultValue, callback)
		end

		function TabData:AddDropdown(text, options, callback, icon)
			return TabData.MainSection:AddDropdown(text, options, callback, icon)
		end

		Window._tabs[name] = TabData
		return TabData
	end

	function Window:SetTitle(text)
		Title.Text = text or ""
	end

	function Window:SetTheme(name)
		local t = Themes[name]
		if not t then return end
		applyTheme(t)
	end

	function Window:SetIcons(leftImageId, closeImageId)
		if leftImageId and leftImageId ~= "" then
			LeftIcon.Image = leftImageId
			LeftIcon.Visible = true
			LeftIconText.Visible = false
		else
			LeftIcon.Visible = false
			LeftIconText.Visible = true
		end

		if closeImageId and closeImageId ~= "" then
			CloseIcon.Image = closeImageId
			CloseIcon.Visible = true
			CloseText.Visible = false
		else
			CloseIcon.Visible = false
			CloseText.Visible = true
		end
	end

	function Window:SetDiscord(imageId, inviteLink, titleText, subText)
		Window._discordLink = inviteLink
		DiscordBanner.Visible = true

		if imageId and imageId ~= "" then
			DiscordBannerImage.Image = imageId
			DiscordBannerImage.Visible = true
		else
			DiscordBannerImage.Visible = false
		end

		if titleText then
			DiscordBannerTitle.Text = titleText
		end

		if subText then
			DiscordBannerSub.Text = subText
		end
	end

	function Window:Notify(text, duration)
		duration = duration or 3

		local Holder = new("Frame", {
			Parent = NotifyHolder,
			BackgroundColor3 = Theme.Card,
			BorderSizePixel = 0,
			Size = UDim2.new(0, 260, 0, 50),
			Position = UDim2.new(1, 280, 1, -70)
		})
		corner(Holder, 10)
		local HolderStroke = stroke(Holder, Theme.Stroke, 1)

		local TitleLabel = new("TextLabel", {
			Parent = Holder,
			BackgroundTransparency = 1,
			Position = UDim2.new(0, 12, 0, 0),
			Size = UDim2.new(1, -24, 1, 0),
			Text = text or "Notify",
			TextColor3 = Theme.Text,
			Font = Enum.Font.GothamSemibold,
			TextSize = 13,
			TextWrapped = true
		})

		Holder.BackgroundTransparency = 1
		TitleLabel.TextTransparency = 1
		HolderStroke.Transparency = 1

		TweenService:Create(Holder, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			BackgroundTransparency = 0,
			Position = UDim2.new(1, -280, 1, -70)
		}):Play()

		TweenService:Create(TitleLabel, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			TextTransparency = 0
		}):Play()

		TweenService:Create(HolderStroke, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Transparency = 0
		}):Play()

		task.delay(duration, function()
			if Holder and Holder.Parent then
				TweenService:Create(Holder, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
					BackgroundTransparency = 1,
					Position = UDim2.new(1, 280, 1, -70)
				}):Play()
				TweenService:Create(TitleLabel, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
					TextTransparency = 1
				}):Play()
				TweenService:Create(HolderStroke, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
					Transparency = 1
				}):Play()
				task.wait(0.2)
				if Holder then
					Holder:Destroy()
				end
			end
		end)
	end

	function Window:ShowFirstTab()
		for _, tab in pairs(Window._tabs) do
			tab.SetActive(false)
		end

		for _, tab in pairs(Window._tabs) do
			tab.SetActive(true)
			Window._selectedTab = tab
			break
		end
	end

	function Window:Destroy()
		if Gui then
			Gui:Destroy()
		end
	end

	applyTheme(Theme)

	if cfg.DiscordBannerImage or cfg.DiscordLink then
		Window:SetDiscord(cfg.DiscordBannerImage, cfg.DiscordLink, cfg.DiscordText, cfg.DiscordSubText)
	end

	if cfg.DefaultTabs and typeof(cfg.DefaultTabs) == "table" then
		for _, tabName in ipairs(cfg.DefaultTabs) do
			makeTab(tostring(tabName))
		end
	end

	Window.AddTab = function(_, tabName, iconId)
		return makeTab(tabName, iconId)
	end

	Window.ResolveIcon = resolveIcon

	return Window
end

return Library
