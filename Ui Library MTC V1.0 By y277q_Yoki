			track("input", Bar, "BackgroundColor3")
			track("fill", Fill, "BackgroundColor3")
			track("text", Label, "TextColor3")
			track("sub", ValueLabel, "TextColor3")

			local function setFromAlpha(alpha, fireCallback)
				alpha = math.clamp(alpha, 0, 1)
				value = math.floor((minValue + (maxValue - minValue) * alpha) + 0.5)
				ValueLabel.Text = tostring(value)

				TweenService:Create(Fill, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
					Size = UDim2.new(alpha, 0, 1, 0)
				}):Play()

				TweenService:Create(Knob, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
					Position = UDim2.new(alpha, 0, 0.5, 0)
				}):Play()

				if fireCallback and callback then
					task.spawn(callback, value)
				end
			end

			local function updateFromInput(inputPos)
				local x = math.clamp((inputPos.X - Bar.AbsolutePosition.X) / Bar.AbsoluteSize.X, 0, 1)
				setFromAlpha(x, true)
			end

			Bar.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					dragging = true
					updateFromInput(input.Position)
				end
			end)

			Knob.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					dragging = true
					updateFromInput(input.Position)
				end
			end)

			UIS.InputChanged:Connect(function(input)
				if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
					updateFromInput(input.Position)
				end
			end)

			UIS.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					dragging = false
				end
			end)

			local Slider = {}

			function Slider:Set(v)
				v = math.clamp(v, minValue, maxValue)
				local alpha = (v - minValue) / (maxValue - minValue)
				setFromAlpha(alpha, true)
			end

			function Slider:Get()
				return value
			end

			Slider:Set(value)
			return Slider
		end

		function SectionApi:AddDropdown(text, options, callback, iconId)
			options = options or {}
			local opened = false
			local selected = nil

			local Holder = new("Frame", {
				Parent = Body,
				BackgroundColor3 = Theme.Button,
				BorderSizePixel = 0,
				Size = UDim2.new(1, 0, 0, 36),
				ClipsDescendants = true
			})
			corner(Holder, 10)
			local HolderStroke = stroke(Holder, Theme.Stroke, 1)

			local MainButton = new("TextButton", {
				Parent = Holder,
				BackgroundTransparency = 1,
				Size = UDim2.new(1, 0, 0, 36),
				Text = "",
				AutoButtonColor = false
			})

			local Icon
			if iconId and iconId ~= "" then
				Icon = new("ImageLabel", {
					Parent = Holder,
					BackgroundTransparency = 1,
					Position = UDim2.new(0, 10, 0.5, -8),
					Size = UDim2.new(0, 16, 0, 16),
					Image = iconId,
					ScaleType = Enum.ScaleType.Fit
				})
				track("text", Icon, "ImageColor3")
			end

			local Label = new("TextLabel", {
				Parent = Holder,
				BackgroundTransparency = 1,
				Position = UDim2.new(0, Icon and 34 or 12, 0, 0),
				Size = UDim2.new(1, -46, 1, 0),
				Text = text or "Dropdown",
				TextColor3 = Theme.Text,
				Font = Enum.Font.GothamSemibold,
				TextSize = 13,
				TextXAlignment = Enum.TextXAlignment.Left
			})

			local Arrow = new("TextLabel", {
				Parent = Holder,
				BackgroundTransparency = 1,
				Position = UDim2.new(1, -24, 0, 0),
				Size = UDim2.new(0, 14, 1, 0),
				Text = "▼",
				TextColor3 = Theme.SubText,
				Font = Enum.Font.GothamBold,
				TextSize = 12
			})

			local List = new("Frame", {
				Parent = Holder,
				BackgroundColor3 = Theme.Card,
				BorderSizePixel = 0,
				Position = UDim2.new(0, 0, 0, 38),
				Size = UDim2.new(1, 0, 0, 0),
				ClipsDescendants = true,
				Visible = false
			})
			corner(List, 8)
			local ListStroke = stroke(List, Theme.Stroke, 1)

			local ListLayout = new("UIListLayout", {
				Parent = List,
				Padding = UDim.new(0, 6),
				SortOrder = Enum.SortOrder.LayoutOrder
			})

			new("UIPadding", {
				Parent = List,
				PaddingTop = UDim.new(0, 6),
				PaddingBottom = UDim.new(0, 6),
				PaddingLeft = UDim.new(0, 6),
				PaddingRight = UDim.new(0, 6)
			})

			local function refreshList()
				for _, child in ipairs(List:GetChildren()) do
					if child:IsA("TextButton") then
						child:Destroy()
					end
				end

				for _, opt in ipairs(options) do
					local Item = new("TextButton", {
						Parent = List,
						BackgroundColor3 = Theme.Input,
						BorderSizePixel = 0,
						Size = UDim2.new(1, 0, 0, 32),
						Text = tostring(opt),
						TextColor3 = Theme.Text,
						Font = Enum.Font.Gotham,
						TextSize = 13,
						AutoButtonColor = false
					})
					corner(Item, 7)
					local ItemStroke = stroke(Item, Theme.Stroke, 1)

					track("input", Item, "BackgroundColor3")
					track("text", Item, "TextColor3")
					track("stroke", ItemStroke, "Color")

					Item.MouseButton1Click:Connect(function()
						selected = tostring(opt)
						Label.Text = (text or "Dropdown") .. " : " .. selected
						opened = false
						List.Visible = false
						Holder.Size = UDim2.new(1, 0, 0, 36)
						Arrow.Text = "▼"
						if callback then
							task.spawn(callback, selected)
						end
					end)
				end

				local count = #options
				local listHeight = math.min(200, 12 + (count * 38))
				List.Size = UDim2.new(1, 0, 0, listHeight)
			end

			track("button", Holder, "BackgroundColor3")
			track("stroke", HolderStroke, "Color")
			track("text", Label, "TextColor3")
			track("sub", Arrow, "TextColor3")
			track("card", List, "BackgroundColor3")
			track("stroke", ListStroke, "Color")

			MainButton.MouseButton1Click:Connect(function()
				opened = not opened
				List.Visible = opened
				Arrow.Text = opened and "▲" or "▼"
				Holder.Size = opened and UDim2.new(1, 0, 0, 42 + List.Size.Y.Offset) or UDim2.new(1, 0, 0, 36)
			end)

			refreshList()

			local Dropdown = {}

			function Dropdown:SetOptions(newOptions)
				options = newOptions or {}
				refreshList()
			end

			function Dropdown:Set(v)
				selected = tostring(v)
				Label.Text = (text or "Dropdown") .. " : " .. selected
				if callback then
					task.spawn(callback, selected)
				end
			end

			function Dropdown:Get()
				return selected
			end

			return Dropdown
		end

		return SectionApi
	end

	local function makeTab(name, iconId)
		local TabButton = new("TextButton", {
			Parent = TabList,
			BackgroundColor3 = Theme.Button,
			BorderSizePixel = 0,
			Size = UDim2.new(1, 0, 0, 38),
			Text = "",
			AutoButtonColor = false
		})
		corner(TabButton, 10)
		local TabStroke = stroke(TabButton, Theme.Stroke, 1)

		local Icon = new("ImageLabel", {
			Parent = TabButton,
			BackgroundTransparency = 1,
			Position = UDim2.new(0, 10, 0.5, -8),
			Size = UDim2.new(0, 16, 0, 16),
			Image = iconId or "",
			Visible = iconId and iconId ~= "",
			ScaleType = Enum.ScaleType.Fit
		})

		local Label = new("TextLabel", {
			Parent = TabButton,
			BackgroundTransparency = 1,
			Position = UDim2.new(0, 34, 0, 0),
			Size = UDim2.new(1, -40, 1, 0),
			Text = name,
			TextColor3 = Theme.Text,
			Font = Enum.Font.GothamSemibold,
			TextSize = 13,
			TextXAlignment = Enum.TextXAlignment.Left
		})

		local TabPage = new("ScrollingFrame", {
			Parent = PagesFolder,
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			Size = UDim2.new(1, 0, 1, 0),
			Visible = false,
			ScrollBarThickness = 4,
			CanvasSize = UDim2.new(0, 0, 0, 0),
			AutomaticCanvasSize = Enum.AutomaticSize.Y
		})

		new("UIListLayout", {
			Parent = TabPage,
			Padding = UDim.new(0, 10),
			SortOrder = Enum.SortOrder.LayoutOrder
		})

		new("UIPadding", {
			Parent = TabPage,
			PaddingTop = UDim.new(0, 10),
			PaddingLeft = UDim.new(0, 10),
			PaddingRight = UDim.new(0, 10),
			PaddingBottom = UDim.new(0, 10)
		})

		track("button", TabButton, "BackgroundColor3")
		track("text", Label, "TextColor3")
		track("stroke", TabStroke, "Color")

		local TabData = {
			Active = false,
			Button = TabButton,
			Page = TabPage,
			ButtonStroke = TabStroke,
			Icon = Icon,
			MainSection = nil
		}

		local function setActive(state)
			TabData.Active = state
			TabPage.Visible = state
			TabButton.BackgroundColor3 = state and Theme.Accent or Theme.Button
		end

		TabButton.MouseButton1Click:Connect(function()
			for _, t in pairs(Window._tabs) do
				t.SetActive(false)
			end
			setActive(true)
		end)

		function TabData.SetActive(state)
			setActive(state)
		end

		TabData.MainSection = makeSection(TabPage, "Main")

		function TabData:AddSection(sectionTitle)
			return makeSection(TabPage, sectionTitle)
		end

		function TabData:AddLabel(text)
			return TabData.MainSection:AddLabel(text)
		end

		function TabData:AddButton(text, callback)
			return TabData.MainSection:AddButton(text, callback)
		end

		function TabData:AddToggle(text, defaultValue, callback, iconId)
			return TabData.MainSection:AddToggle(text, defaultValue, callback, iconId)
		end

		function TabData:AddSlider(text, minValue, maxValue, defaultValue, callback, iconId)
			return TabData.MainSection:AddSlider(text, minValue, maxValue, defaultValue, callback, iconId)
		end

		function TabData:AddDropdown(text, options, callback, iconId)
			return TabData.MainSection:AddDropdown(text, options, callback, iconId)
		end

		Window._tabs[name] = TabData
		return TabData
	end

	function Window:SetTitle(text)
		Title.Text = text or ""
	end

	function Window:SetTheme(themeName)
		local t = Themes[themeName]
		if not t then return end
		applyTheme(t)
	end

	function Window:SetIcons(leftImageId, closeImageId)
		if leftImageId and leftImageId ~= "" then
			LeftIcon.Image = leftImageId
			LeftIcon.Visible = true
			LeftIconText.Visible = false
		else
			LeftIcon.Visible = false
			LeftIconText.Visible = true
		end

		if closeImageId and closeImageId ~= "" then
			CloseIcon.Image = closeImageId
			CloseIcon.Visible = true
			CloseText.Visible = false
		else
			CloseIcon.Visible = false
			CloseText.Visible = true
		end
	end

	function Window:SetDiscord(imageId, inviteLink, titleText, subText)
		Window._discordLink = inviteLink
		DiscordBanner.Visible = true

		if imageId and imageId ~= "" then
			DiscordBannerImage.Image = imageId
			DiscordBannerImage.Visible = true
		else
			DiscordBannerImage.Visible = false
		end

		if titleText then
			DiscordBannerTitle.Text = titleText
		end

		if subText then
			DiscordBannerSub.Text = subText
		end
	end

	function Window:Notify(opts)
		if typeof(opts) == "string" then
			opts = { Text = opts }
		end
		opts = opts or {}

		local text = opts.Text or "Notify"
		local icon = opts.Icon or ""
		local duration = opts.Duration or 3
		local timeText = opts.TimeText or os.date("%H:%M")

		local Holder = new("Frame", {
			Parent = NotifyHolder,
			BackgroundColor3 = Theme.Card,
			BorderSizePixel = 0,
			Size = UDim2.new(0, 280, 0, 56),
			Position = UDim2.new(1, 300, 1, -76)
		})
		corner(Holder, 10)
		local HolderStroke = stroke(Holder, Theme.Stroke, 1)

		local IconLabel = new("ImageLabel", {
			Parent = Holder,
			BackgroundTransparency = 1,
			Position = UDim2.new(0, 12, 0.5, -10),
			Size = UDim2.new(0, 20, 0, 20),
			Image = icon,
			Visible = icon ~= "",
			ScaleType = Enum.ScaleType.Fit
		})

		local TextLabel = new("TextLabel", {
			Parent = Holder,
			BackgroundTransparency = 1,
			Position = UDim2.new(0, icon ~= "" and 40 or 12, 0, 0),
			Size = UDim2.new(1, icon ~= "" and -96 or -68, 1, 0),
			Text = text,
			TextColor3 = Theme.Text,
			Font = Enum.Font.GothamSemibold,
			TextSize = 13,
			TextXAlignment = Enum.TextXAlignment.Left,
			TextWrapped = true
		})

		local TimeLabel = new("TextLabel", {
			Parent = Holder,
			BackgroundTransparency = 1,
			Position = UDim2.new(1, -58, 0, 0),
			Size = UDim2.new(0, 46, 0, 20),
			Text = timeText,
			TextColor3 = Theme.SubText,
			Font = Enum.Font.Gotham,
			TextSize = 11,
			TextXAlignment = Enum.TextXAlignment.Right
		})

		Holder.BackgroundTransparency = 1
		TextLabel.TextTransparency = 1
		TimeLabel.TextTransparency = 1
		if IconLabel.Visible then
			IconLabel.ImageTransparency = 1
		end
		HolderStroke.Transparency = 1

		playShow(Holder, {
			BackgroundTransparency = 0,
			Position = UDim2.new(1, -300, 1, -76)
		}, 0.18)

		playShow(TextLabel, { TextTransparency = 0 }, 0.18)
		playShow(TimeLabel, { TextTransparency = 0 }, 0.18)
		playShow(HolderStroke, { Transparency = 0 }, 0.18)
		if IconLabel.Visible then
			playShow(IconLabel, { ImageTransparency = 0 }, 0.18)
		end

		task.delay(duration, function()
			if Holder and Holder.Parent then
				playShow(Holder, {
					BackgroundTransparency = 1,
					Position = UDim2.new(1, 300, 1, -76)
				}, 0.18)
				playShow(TextLabel, { TextTransparency = 1 }, 0.12)
				playShow(TimeLabel, { TextTransparency = 1 }, 0.12)
				playShow(HolderStroke, { Transparency = 1 }, 0.12)
				if IconLabel.Visible then
					playShow(IconLabel, { ImageTransparency = 1 }, 0.12)
				end
				task.wait(0.2)
				if Holder then
					Holder:Destroy()
				end
			end
		end)
	end

	function Window:ShowFirstTab()
		for _, tab in pairs(Window._tabs) do
			tab.SetActive(false)
		end
		for _, tab in pairs(Window._tabs) do
			tab.SetActive(true)
			break
		end
	end

	function Window:Destroy()
		if Gui then
			Gui:Destroy()
		end
	end

	applyTheme(Theme)

	if cfg.DiscordBannerImage or cfg.DiscordLink then
		Window:SetDiscord(cfg.DiscordBannerImage, cfg.DiscordLink, cfg.DiscordText, cfg.DiscordSubText)
	end

	Window.AddTab = function(_, tabName, iconId)
		return makeTab(tabName, iconId)
	end

	if cfg.DefaultTabs and typeof(cfg.DefaultTabs) == "table" then
		for _, tabName in ipairs(cfg.DefaultTabs) do
			makeTab(tostring(tabName), "")
		end
	end

	return Window
end

return Library
