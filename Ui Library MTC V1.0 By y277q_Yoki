			local Switch = new("Frame", {
				Parent = Holder,
				BackgroundColor3 = state and Theme.Accent or Theme.Stroke,
				BorderSizePixel = 0,
				Size = UDim2.new(0, 44, 0, 22),
				Position = UDim2.new(1, -56, 0.5, -11)
			})
			corner(Switch, 999)

			local Knob = new("Frame", {
				Parent = Switch,
				BackgroundColor3 = Color3.fromRGB(255, 255, 255),
				BorderSizePixel = 0,
				AnchorPoint = Vector2.new(0, 0),
				Size = UDim2.new(0, 16, 0, 16),
				Position = state and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 3, 0.5, -8)
			})
			corner(Knob, 999)

			track("button", Holder, "BackgroundColor3")
			track("stroke", HolderStroke, "Color")
			track("text", Label, "TextColor3")
			track("fill", Switch, "BackgroundColor3")

			local function render()
				playShow(Knob, {
					Position = state and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 3, 0.5, -8)
				}, 0.15)

				playShow(Switch, {
					BackgroundColor3 = state and Theme.Accent or Theme.Stroke
				}, 0.15)

				if callback then
					task.spawn(callback, state)
				end
			end

			Holder.MouseButton1Click:Connect(function()
				state = not state
				render()
			end)

			local Toggle = {}

			function Toggle:Set(v)
				state = v and true or false
				render()
			end

			function Toggle:Get()
				return state
			end

			render()
			return Toggle
		end

